APP_NAME="DREAM Attitude"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://dreamattitude.al-mhaf.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database — use MySQL on production (Hostinger). SQLite acceptable for local only.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=commerce
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# Commerce — store identity (override via Admin → Settings when built)
# -----------------------------------------------------------------------------
COMMERCE_STORE_NAME="${APP_NAME}"
COMMERCE_CURRENCY=INR
COMMERCE_TIMEZONE=Asia/Kolkata
COMMERCE_GUEST_CHECKOUT=true
COMMERCE_REVIEWS_ENABLED=true
COMMERCE_WISHLIST_ENABLED=true
COMMERCE_MAINTENANCE=false
COMMERCE_LOW_STOCK_THRESHOLD=5
COMMERCE_BULK_MIN_QTY=0

# -----------------------------------------------------------------------------
# Payments — Razorpay (India)
# -----------------------------------------------------------------------------
RAZORPAY_KEY=
RAZORPAY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Meta — Pixel + Conversions API
# -----------------------------------------------------------------------------
META_PIXEL_ID=342821102141032
META_CAPI_ACCESS_TOKEN=
META_CAPI_TEST_EVENT_CODE=

# -----------------------------------------------------------------------------
# Google — GA4 + Merchant Center (optional ID for feeds UI)
# -----------------------------------------------------------------------------
GA4_MEASUREMENT_ID=
GOOGLE_MERCHANT_ID=

# -----------------------------------------------------------------------------
# Google Tag Manager (preferred single injection point for tags)
# -----------------------------------------------------------------------------
GTM_CONTAINER_ID=

# -----------------------------------------------------------------------------
# WhatsApp Cloud API (optional; fallback wa.me links work without)
# -----------------------------------------------------------------------------
WHATSAPP_BUSINESS_NUMBER=
WHATSAPP_CLOUD_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# -----------------------------------------------------------------------------
# Shipping — Shiprocket / Delhivery (optional)
# -----------------------------------------------------------------------------
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
SHIPROCKET_WEBHOOK_SECRET=

DELHIVERY_API_TOKEN=
DELHIVERY_CLIENT_ID=

# -----------------------------------------------------------------------------
# License (optional; per-deployment white-label)
# -----------------------------------------------------------------------------
COMMERCE_LICENSE_KEY=
COMMERCE_LICENSE_DOMAIN=
COMMERCE_LICENSE_ENFORCE=false
